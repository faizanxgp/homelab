<clickhouse>
    <logger>
        <level>warning</level>
        <console>true</console>
    </logger>
    <!-- Native Prometheus endpoint, scraped by the homelab Prometheus on :9363 -->
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
        <status_info>true</status_info>
    </prometheus>
</clickhouse>
