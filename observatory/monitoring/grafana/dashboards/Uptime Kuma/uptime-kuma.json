  "tags": [
    "uptime-kuma",
    "monitoring",
    "homelab"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
