{
  "uid": "obsidian-vault",
  "title": "Obsidian \u2014 Vault (via CouchDB)",
  "tags": [
    "obsidian",
    "homelab",
    "couchdb"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "vault",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "label": "Vault DB",
        "query": {
          "qryType": 1,
          "query": "label_values(couchdb_database_doc_count{db_name!~\"_.*\"}, db_name)",
          "refId": "var"
        },
        "definition": "label_values(couchdb_database_doc_count{db_name!~\"_.*\"}, db_name)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 265,
      "type": "stat",
      "title": "Documents (notes + sync chunks)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
