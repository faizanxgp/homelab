{
  "uid": "vault-files-logs",
  "title": "Vault & Files — Logs",
  "tags": ["logs", "homelab", "obsidian", "webdav"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "timezone": "browser",
  "templating": { "list": [] },
  "annotations": { "list": [ { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" }, "enable": true, "hide": true, "name": "Annotations & Alerts", "type": "dashboard" } ] },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Log volume by source (lines/interval)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 7 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } }, "unit": "short" }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] } },
      "targets": [
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({container=\"obsidian\"}[$__interval]))", "legendFormat": "obsidian (livesync)", "refId": "A" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({container=\"webdav\"}[$__interval]))", "legendFormat": "webdav", "refId": "B" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({container=\"couchdb\"}[$__interval]))", "legendFormat": "couchdb", "refId": "C" },
        { "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum(count_over_time({job=\"homelab-jobs\"}[$__interval]))", "legendFormat": "vault→github cron", "refId": "D" }
      ]
    },
    {
      "id": 2, "type": "logs", "title": "Vault → GitHub sync (cron, Mon & Thu) + host jobs (rclone)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 8 },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "expr": "{job=\"homelab-jobs\"}", "refId": "A" } ]
    },
    {
      "id": 3, "type": "logs", "title": "WebDAV (dav.itproxima.com) access & auth",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 9 },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "expr": "{container=\"webdav\"}", "refId": "A" } ]
    },
    {
      "id": 4, "type": "logs", "title": "Obsidian web vault (KasmVNC + LiveSync)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 9 },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "expr": "{container=\"obsidian\"}", "refId": "A" } ]
    }
  ]
}
